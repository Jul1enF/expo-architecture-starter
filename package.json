{
  "name": "my-app-name",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "publish:main": "yarn clear-react-native-cache && eas update",
    "ts-check" : "tsc --noEmit",
    "clear-react-native-cache": "rm -rf $TMPDIR/react-* && rm -rf $TMPDIR/metro-* && rm -rf $TMPDIR/haste-map-*",
    "clear-expo-cache": "rm -rf node_modules && yarn cache clean && yarn && rm -rf $TMPDIR/react-* && rm -rf $TMPDIR/metro-* && rm -rf $TMPDIR/haste-map-*"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.5.0",
    "@types/react": "~19.2.10",
    "@types/react-native": "^0.73.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo": "^55.0.23",
    "expo-application": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-screen-orientation": "~55.0.14",
    "expo-splash-screen": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-modal": "^13.0.1",
    "react-native-restart-newarch": "^1.0.85",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-redux": "^9.2.0",
    "typescript": "~5.9.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0"
  },
  "private": true
}
